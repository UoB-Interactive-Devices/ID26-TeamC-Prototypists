<robot name="robot_arm">
 	<link name="base_link">
		<visual>
		    <origin xyz="0 0 0.037" rpy="0 0 0"/>
			<geometry>
				<cylinder length="0.074" radius="0.075"/>
			</geometry>
		</visual>
	</link>
    <link name="base_rot">
		<visual>
            <origin xyz="0 0 0.033" rpy="0 0 0"/>
          	<geometry>
				<cylinder length="0.066" radius="0.075"/>
			</geometry>
		</visual>
	</link>
    <joint name="base_joint" type="revolute">
      <parent link="base_link"/>
      <child link="base_rot"/>
      <origin xyz="0 0 0.074" rpy="0 0 0" />
      <axis xyz="0 0 -1"/>
    <limit lower="-3.14" upper="3.14" />
    </joint>
    <link name="arm1">
        <!-- shoulder (L1 = 195mm) -->
		<visual>
          <origin xyz="0 0 0.0975" rpy="0 0 0" />
          	<geometry>
            	<cylinder length="0.195" radius="0.022"/>
			</geometry>
		</visual>
	</link>
    <joint name="shoulder_joint" type="revolute">
      <parent link="base_rot"/>
      <child link="arm1"/>
      <origin xyz="0 0 0.066" rpy="0 0 0" />
      <axis xyz="0 1 0"/>
      <limit lower="-1.57" upper="1.57" />
    </joint>
    <link name="arm2">
        <!-- elbow (L2 = 120mm) -->
		<visual>
          <origin xyz="0 0 0.060" rpy="0 0 0" />
          	<geometry>
            	<cylinder length="0.120" radius="0.0175"/>
			</geometry>
		</visual>
	</link>
    <link name="wrist">
		<visual>
          <origin xyz="0 0 0.0425" rpy="0 0 0" />
          	<geometry>
            	<cylinder length="0.085" radius="0.0125"/>
			</geometry>
		</visual>
    </link>
    <link name="gripper">
		<visual>
          <origin xyz="0 0 0.0725" rpy="0 0 0" />
          	<geometry>
            	<box size="0.045 0.005 0.145" />
			</geometry>
		</visual>
	</link>
    <!-- Logical endpoint representing the tip of the gripper.
         No visual; used by IKPy as the end effector target. -->
    <link name="tool_tip"/>
    <joint name="elbow_joint" type="revolute">
      <parent link="arm1"/>
      <child link="arm2"/>
      <origin xyz="0 0 0.195" rpy="0 0 0" />
      <axis xyz="0 1 0"/>
        <limit lower="-1.60" upper="1.53" />
    </joint>
    <joint name="wrist_joint" type="revolute">
      <parent link="arm2"/>
      <child link="wrist"/>
      <origin xyz="0 0 0.12" rpy="0 0 0" />
      <axis xyz="0 -1 0"/>
      <limit lower="-1.4" upper="1.75" />
    </joint>
    <joint name="wrist_rot_joint" type="revolute">
      <parent link="wrist"/>
      <child link="gripper"/>
      <origin xyz="0 0 0.085" rpy="0 0 0" />
      <axis xyz="0 0 -1"/>
      <limit lower="-1.78" upper="0.48" />
    </joint>
    <!-- Fixed joint from the base of the gripper to its tip.
         145mm = measured distance from wrist_rot servo to gripper tip. -->
    <joint name="tool_joint" type="fixed">
      <parent link="gripper"/>
      <child link="tool_tip"/>
      <origin xyz="0 0 0.145" rpy="0 0 0"/>
    </joint>
</robot>
