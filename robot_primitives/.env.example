TELEGRAM_BOT_TOKEN=replace_with_botfather_token
TELEGRAM_ALLOWED_CHAT_ID=replace_with_your_chat_id
ROBOT_ARM_SERIAL_PORT=/dev/cu.usbmodem1101
ROBOT_ARM_BAUDRATE=115200
ROBOT_ARM_DETECT_URL=http://127.0.0.1:8080/detect

# Natural language mode:
# - rules: local keyword parser only
# - openclaw: send Telegram text to OPENCLAW_INTENT_COMMAND first, then fall back to rules
ROBOT_ARM_NL_INTERPRETER=rules
OPENCLAW_INTENT_COMMAND=
OPENCLAW_INTENT_TIMEOUT=20
